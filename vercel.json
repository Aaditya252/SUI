{
  "builds": [
    { "src": "ui/**", "use": "@vercel/static" },
    { "src": "api/**", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/ui/startingpage.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/ui/$1" }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
